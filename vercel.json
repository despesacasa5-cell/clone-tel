
{
  "version": 2,
  "buildCommand": null,
  "outputDirectory": "public",
  "installCommand": "npm install",
  "framework": null,
  "builds": [
    {
      "src": "api/*.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/auth",
      "dest": "/api/auth.js"
    },
    {
      "src": "/api/groups",
      "dest": "/api/groups.js"
    },
    {
      "src": "/api/clone",
      "dest": "/api/clone.js"
    },
    {
      "src": "/(.*)",
      "dest": "/public/$1"
    }
  ],
  "functions": {
    "api/*.js": {
      "maxDuration": 300,
      "memory": 1024
    }
  }
}